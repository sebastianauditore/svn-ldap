# SVN Configuration
SVN_ROOT=/var/svn

# LDAP Server
AuthLDAPURL=ldap://ldap.example.com:389/dc=example,dc=com?uid?sub?(objectClass=person)
AuthLDAPBindDN=cn=readonly,dc=example,dc=com
AuthLDAPBindPassword=yourpassword

# LDAP Groups
RequireLDAPGroup=svn-users
LDAPBaseDN=dc=example,dc=com

# UI
AuthName=My Company SVN Repository

# Optional: Read-only user for CI/CD
ReadOnlyUser=redmine

# Reverse Proxy
BehindSSLProxy=true
